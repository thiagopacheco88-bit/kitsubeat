# .env.test.example — copy to .env.test and fill in values.
#
# This file documents the environment required to run the QA suite (Phase 08.1).
# .env.test is gitignored — never commit real connection strings.

# Postgres connection string for the dedicated test database.
# Point this at a SEPARATE database from DATABASE_URL — the test suite truncates
# user_song_progress / user_vocab_mastery / user_exercise_log between runs and would
# wipe your dev progress otherwise.
#
# Setup:
#   1. Create a new database on the same Neon project:
#        createdb kitsubeat_test
#   2. Set TEST_DATABASE_URL below.
#   3. Populate the catalog by running `npm run seed:dev` against TEST_DATABASE_URL.
#   4. Run `npx tsx tests/support/seed-test-db.ts` (alias: `npm run test:seed`)
#      to verify the catalog contains the slugs the suite expects.
TEST_DATABASE_URL=postgres://USER:PASSWORD@HOST/kitsubeat_test?sslmode=require

# UI/runtime hint that lets the app branch on test mode if a future test needs to
# bypass a real-world side effect (e.g. analytics beacon). Reserved — no code change yet.
NEXT_PUBLIC_APP_ENV=test
