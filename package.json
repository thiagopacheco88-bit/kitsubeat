    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "build:manifest": "npx tsx --tsconfig tsconfig.scripts.json scripts/seed/01-build-manifest.ts",
    "qa:coverage": "npx tsx --tsconfig tsconfig.scripts.json scripts/seed/06-qa-agent.ts",
    "seed:dev": "npx tsx --tsconfig tsconfig.scripts.json scripts/seed/07-dev-seed.ts",
    "pipeline": "npx tsx --tsconfig tsconfig.scripts.json scripts/seed/run-pipeline.ts",
    "generate:lessons": "npx tsx --tsconfig tsconfig.scripts.json scripts/seed/03b-generate-content-sequential.ts",
    "seed:enrich-vocab": "tsx --tsconfig tsconfig.scripts.json scripts/seed/11-enrich-vocab.ts",
    "backfill:vocab": "tsx --tsconfig tsconfig.scripts.json scripts/backfill-vocab-identity.ts",
    "audit:geo": "tsx --tsconfig tsconfig.scripts.json scripts/backfill-geo-check.ts",
    "audit:geo:replace": "tsx --tsconfig tsconfig.scripts.json scripts/backfill-geo-check.ts --replace",
    "audit:verse-tokens": "tsx --tsconfig tsconfig.scripts.json scripts/audit/verse-token-distribution.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "playwright test",
    "test:qa": "tsx --tsconfig tsconfig.scripts.json scripts/seed/06-qa-agent.ts",
    "test:qa:uuid": "tsx --tsconfig tsconfig.scripts.json scripts/seed/06-qa-uuid-integrity.ts",
    "test:qa:geo": "tsx --tsconfig tsconfig.scripts.json scripts/seed/06-qa-geo-check.ts",
    "test:seed": "tsx tests/support/seed-test-db.ts",
    "test:report": "playwright show-report",
    "test:all": "npm run test:seed && npm run test:unit && npm run test:integration && npm run test:qa && npm run test:e2e",
    "test:measure": "tsx scripts/qa/measure-suite-runtime.ts",
    "test:ci-pr": "npm run test:qa && npm run test:unit && npm run test:integration",
    "test:ci-nightly": "tsx scripts/qa/measure-suite-runtime.ts",
    "test:quarantine": "tsx scripts/qa/run-quarantined.ts",
    "test:qa:enrichment": "tsx --tsconfig tsconfig.scripts.json scripts/seed/12-qa-enrichment.ts"
  },
  "dependencies": {
