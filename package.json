    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "next": "^15.5.14",
    "p-limit": "^6.2.0",
    "postcss": "^8.5.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "ts-fsrs": "^5.3.2",
    "wavesurfer.js": "^7.12.5",
    "zod": "^3.24.3",
    "zod-to-json-schema": "^3.24.5",
    "zustand": "^5.0.12"
